      "message": "    \u003cdiv x-show\u003d\"!highlightedCode\"\u003e\u003cpre\u003e\u003ccode\u003e\u003cspan class\u003d\"block px-4 py-1 h-7 even:bg-white odd:bg-white/2 even:dark:bg-white/2 odd:dark:bg-white/4 \"\u003e\u003cspan class\u003d\"mr-6 text-neutral-500! dark:text-neutral-600! \"\u003e82\u003c/span\u003e            },\u003c/span\u003e\u003cspan class\u003d\"block px-4 py-1 h-7 even:bg-white odd:bg-white/2 even:dark:bg-white/2 odd:dark:bg-white/4 \"\u003e\u003cspan class\u003d\"mr-6 text-neutral-500! dark:text-neutral-600! \"\u003e83\u003c/span\u003e            \u0026#039;contracts\u0026#039; \u003d\u0026gt; function($query) {\u003c/span\u003e\u003cspan class\u003d\"block px-4 py-1 h-7 even:bg-white odd:bg-white/2 even:dark:bg-white/2 odd:dark:bg-white/4 \"\u003e\u003cspan class\u003d\"mr-6 text-neutral-500! dark:text-neutral-600! \"\u003e84\u003c/span\u003e                // Chỉ load ra những hợp đồng đang có hiệu lực hoặc đang chờ hủy\u003c/span\u003e\u003cspan class\u003d\"block px-4 py-1 h-7 even:bg-white odd:bg-white/2 even:dark:bg-white/2 odd:dark:bg-white/4 \"\u003e\u003cspan class\u003d\"mr-6 text-neutral-500! dark:text-neutral-600! \"\u003e85\u003c/span\u003e                $query-\u0026gt;whereIn(\u0026#039;status\u0026#039;, [\u0026#039;active\u0026#039;, \u0026#039;pending_termination\u0026#039;]);\u003c/span\u003e\u003cspan class\u003d\"block px-4 py-1 h-7 even:bg-white odd:bg-white/2 even:dark:bg-white/2 odd:dark:bg-white/4 \"\u003e\u003cspan class\u003d\"mr-6 text-neutral-500! dark:text-neutral-600! \"\u003e86\u003c/span\u003e            }\u003c/span\u003e\u003cspan class\u003d\"block px-4 py-1 h-7 even:bg-white odd:bg-white/2 even:dark:bg-white/2 odd:dark:bg-white/4 bg-rose-200! dark:bg-rose-900!\"\u003e\u003cspan class\u003d\"mr-6 text-neutral-500! dark:text-neutral-600! dark:text-white!\"\u003e87\u003c/span\u003e        ])-\u0026gt;find($id);\u003c/span\u003e\u003cspan class\u003d\"block px-4 py-1 h-7 even:bg-white odd:bg-white/2 even