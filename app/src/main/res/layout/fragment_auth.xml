<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_padding_horizontal"
    android:paddingTop="@dimen/screen_padding_vertical"
    android:paddingEnd="@dimen/screen_padding_horizontal"
    android:paddingBottom="@dimen/screen_padding_bottom">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_auth"
        android:textAppearance="@style/TextAppearance.SmartRent.TitleLarge" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:text="@string/placeholder_auth"
        android:textAppearance="@style/TextAppearance.SmartRent.BodySecondary" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.SmartRent.Card.Compact"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/section_spacing"
        app:contentPadding="@dimen/card_padding_compact">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/skeleton_content_area"
            android:textAppearance="@style/TextAppearance.SmartRent.BodySecondary" />
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
