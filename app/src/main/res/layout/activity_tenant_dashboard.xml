<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6F8"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xin chào, Khách thuê!"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"/>
        <ImageView
            android:id="@+id/btnLogout"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Đăng xuất"/>
    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin phòng"
                android:textStyle="bold"
                android:textColor="#555555"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:id="@+id/tvRoomName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phòng: Đang tải..."
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1976D2"/>
            <TextView
                android:id="@+id/tvRoomPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giá thuê: Đang tải..."
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hóa đơn tháng này"
                android:textStyle="bold"
                android:textColor="#555555"/>
            <TextView
                android:id="@+id/tvBillAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa có hóa đơn"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnPayMoMo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thanh toán qua MoMo"
                android:backgroundTint="#A50064"
                android:textColor="#FFFFFF"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btnSplitBill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chia tiền linh hoạt"
                android:backgroundTint="#607D8B"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnReportIncident"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Báo cáo sự cố"
        android:textSize="16sp"
        android:backgroundTint="#1976D2"
        app:cornerRadius="8dp"/>

</LinearLayout>
