<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/screen_padding_vertical"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingBottom="@dimen/screen_padding_bottom">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_notification_detail"
            android:textAppearance="@style/TextAppearance.SmartRent.TitleLarge" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="@string/notification_detail_subtitle"
            android:textAppearance="@style/TextAppearance.SmartRent.BodySecondary" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartRent.Card.Elevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            app:cardBackgroundColor="@color/sr_info_container"
            app:contentPadding="@dimen/card_padding"
            app:strokeColor="@color/sr_info_container">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        style="@style/Widget.SmartRent.StatusChip.Info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/notification_detail_type" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/component_gap"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/notification_status_unread"
                        android:textAppearance="@style/TextAppearance.SmartRent.Caption"
                        android:textColor="@color/sr_primary" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/form_field_gap"
                    android:text="@string/notification_detail_title"
                    android:textAppearance="@style/TextAppearance.SmartRent.TitleMedium" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/component_gap"
                    android:text="@string/notification_detail_body"
                    android:textAppearance="@style/TextAppearance.SmartRent.Body" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/form_field_gap"
                    android:text="@string/notification_detail_meta"
                    android:textAppearance="@style/TextAppearance.SmartRent.Caption" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:text="@string/notification_detail_related_title"
            android:textAppearance="@style/TextAppearance.SmartRent.SectionTitle" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartRent.Card.State"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/form_field_gap"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/notification_detail_related_bill"
                    android:textAppearance="@style/TextAppearance.SmartRent.TitleMedium" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="@string/notification_detail_related_amount"
                    android:textAppearance="@style/TextAppearance.SmartRent.Money" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/viewRelatedBillButton"
                    style="@style/Widget.SmartRent.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:text="@string/notification_detail_view_bill" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/viewRelatedRoomButton"
                    style="@style/Widget.SmartRent.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/component_gap"
                    android:text="@string/notification_detail_view_room" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/markReadButton"
            style="@style/Widget.SmartRent.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:enabled="false"
            android:text="@string/notification_detail_mark_read" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
