<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F8F9FA">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BÁO CÁO SỰ CỐ"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1976D2"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tiêu đề sự cố:"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"/>
    <EditText
        android:id="@+id/etTitle"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="VD: Hỏng vòi nước, Mất điện..."
        android:inputType="text"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mô tả chi tiết:"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"/>
    <EditText
        android:id="@+id/etDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập chi tiết tình trạng sự cố để chúng tôi xử lý nhanh hơn..."
        android:inputType="textMultiLine"
        android:lines="5"
        android:gravity="top"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnSendReport"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="GỬI BÁO CÁO"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"/>

</LinearLayout>
