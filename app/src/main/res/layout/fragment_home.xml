<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="@dimen/main_content_bottom_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/screen_padding_vertical"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingBottom="@dimen/screen_padding_bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="@dimen/avatar_size_md"
                android:layout_height="@dimen/avatar_size_md"
                android:background="@drawable/bg_empty_state_icon"
                android:gravity="center"
                android:text="@string/home_avatar_initials"
                android:textAppearance="@style/TextAppearance.SmartRent.H2"
                android:textColor="@color/sr_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_greeting_title"
                    android:textAppearance="@style/TextAppearance.SmartRent.H1" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_1"
                    android:text="@string/home_space_name"
                    android:textAppearance="@style/TextAppearance.SmartRent.BodySmall" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/notificationButton"
                style="@style/Widget.SmartRent.IconButton"
                android:layout_width="@dimen/icon_button_size"
                android:layout_height="@dimen/icon_button_size"
                android:contentDescription="@string/home_notification_action"
                app:icon="@drawable/ic_home_notifications"
                app:iconGravity="textStart" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="@string/home_greeting_subtitle"
            android:textAppearance="@style/TextAppearance.SmartRent.BodySecondary" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartRent.Card.Elevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            app:cardBackgroundColor="@color/sr_primary"
            app:contentPadding="@dimen/card_padding"
            app:strokeColor="@color/sr_primary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_overview_month_revenue"
                    android:textAppearance="@style/TextAppearance.SmartRent.Label"
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="@string/home_value_month_revenue"
                    android:textAppearance="@style/TextAppearance.SmartRent.Display"
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="@string/home_hint_month_revenue"
                    android:textAppearance="@style/TextAppearance.SmartRent.BodySmall"
                    android:textColor="@color/sr_primary_light" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:text="@string/home_overview_title"
            android:textAppearance="@style/TextAppearance.SmartRent.H2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SmartRent.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_4"
                android:layout_weight="1"
                app:contentPadding="@dimen/card_padding_compact">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/home_overview_rooms_total"
                        android:textAppearance="@style/TextAppearance.SmartRent.Caption" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        android:text="@string/home_value_rooms_total"
                        android:textAppearance="@style/TextAppearance.SmartRent.H1" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        android:text="@string/home_hint_rooms_total"
                        android:textAppearance="@style/TextAppearance.SmartRent.Caption" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SmartRent.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/sr_info_container"
                app:contentPadding="@dimen/card_padding_compact"
                app:strokeColor="@color/sr_info_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/home_overview_rooms_occupied"
                        android:textAppearance="@style/TextAppearance.SmartRent.Caption"
                        android:textColor="@color/sr_info_text" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        android:text="@string/home_value_rooms_occupied"
                        android:textAppearance="@style/TextAppearance.SmartRent.H1"
                        android:textColor="@color/sr_info_text" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        android:text="@string/home_hint_rooms_occupied"
                        android:textAppearance="@style/TextAppearance.SmartRent.Caption"
                        android:textColor="@color/sr_info_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SmartRent.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_4"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/sr_vacant_container"
                app:contentPadding="@dimen/card_padding_compact"
                app:strokeColor="@color/sr_vacant_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/home_overview_rooms_available"
                        android:textAppearance="@style/TextAppearance.SmartRent.Caption"
                        android:textColor="@color/sr_vacant_text" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        android:text="@string/home_value_rooms_available"
                        android:textAppearance="@style/TextAppearance.SmartRent.H1"
                        android:textColor="@color/sr_vacant_text" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        android:text="@string/home_hint_rooms_available"
                        android:textAppearance="@style/TextAppearance.SmartRent.Caption"
                        android:textColor="@color/sr_vacant_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SmartRent.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/sr_warning_container"
                app:contentPadding="@dimen/card_padding_compact"
                app:strokeColor="@color/sr_warning_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/home_overview_bills_pending"
                        android:textAppearance="@style/TextAppearance.SmartRent.Caption"
                        android:textColor="@color/sr_warning_text" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        android:text="@string/home_value_bills_pending"
                        android:textAppearance="@style/TextAppearance.SmartRent.H1"
                        android:textColor="@color/sr_warning_text" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        android:text="@string/home_hint_bills_pending"
                        android:textAppearance="@style/TextAppearance.SmartRent.Caption"
                        android:textColor="@color/sr_warning_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartRent.Card.State"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            app:cardBackgroundColor="@color/sr_warning_container"
            app:strokeColor="@color/sr_warning_container">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.chip.Chip
                    style="@style/Widget.SmartRent.StatusChip.Warning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_hint_bills_pending" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/home_billing_reminder_title"
                    android:textAppearance="@style/TextAppearance.SmartRent.H3"
                    android:textColor="@color/sr_warning_text" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="@string/home_billing_reminder_content"
                    android:textAppearance="@style/TextAppearance.SmartRent.BodySmall"
                    android:textColor="@color/sr_warning_text" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/openBillsReminderButton"
                    style="@style/Widget.SmartRent.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="@string/home_billing_reminder_action" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:text="@string/home_quick_actions_title"
            android:textAppearance="@style/TextAppearance.SmartRent.H2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addRoomButton"
                style="@style/Widget.SmartRent.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_4"
                android:layout_weight="1"
                android:text="@string/home_quick_add_room" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addTenantButton"
                style="@style/Widget.SmartRent.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4"
                android:layout_weight="1"
                android:text="@string/home_quick_add_tenant" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/createBillButton"
                style="@style/Widget.SmartRent.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_4"
                android:layout_weight="1"
                android:text="@string/home_quick_create_bill" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/recordMeterButton"
                style="@style/Widget.SmartRent.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4"
                android:layout_weight="1"
                android:text="@string/home_quick_record_meter" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:text="@string/home_recent_activity_title"
            android:textAppearance="@style/TextAppearance.SmartRent.H2" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SmartRent.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            app:contentPadding="@dimen/card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_recent_activity_tenant_title"
                    android:textAppearance="@style/TextAppearance.SmartRent.H3" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="@string/home_recent_activity_tenant_body"
                    android:textAppearance="@style/TextAppearance.SmartRent.BodySmall" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_1"
                    android:text="@string/home_activity_time_now"
                    android:textAppearance="@style/TextAppearance.SmartRent.Caption" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/stroke_thin"
                    android:layout_marginTop="@dimen/space_12"
                    android:layout_marginBottom="@dimen/space_12"
                    android:background="@color/sr_divider" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_recent_activity_bill_title"
                    android:textAppearance="@style/TextAppearance.SmartRent.H3" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="@string/home_recent_activity_bill_body"
                    android:textAppearance="@style/TextAppearance.SmartRent.BodySmall" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_1"
                    android:text="@string/home_activity_time_today"
                    android:textAppearance="@style/TextAppearance.SmartRent.Caption" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/stroke_thin"
                    android:layout_marginTop="@dimen/space_12"
                    android:layout_marginBottom="@dimen/space_12"
                    android:background="@color/sr_divider" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_recent_activity_room_title"
                    android:textAppearance="@style/TextAppearance.SmartRent.H3" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="@string/home_recent_activity_room_body"
                    android:textAppearance="@style/TextAppearance.SmartRent.BodySmall" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_1"
                    android:text="@string/home_activity_time_yesterday"
                    android:textAppearance="@style/TextAppearance.SmartRent.Caption" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
