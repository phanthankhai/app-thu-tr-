<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="← Hủy và Quay lại"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#F44336"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="THÊM PHÒNG TRỌ MỚI"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <ImageView
            android:id="@+id/ivSelectRoomImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#E0E0E0"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnChooseImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chọn ảnh phòng"
            android:backgroundTint="#9C27B0"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/etRoomName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Tên/Số phòng (Ví dụ: 105)"
            android:inputType="text"
            android:background="@android:color/white"
            android:paddingLeft="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etRoomPrice"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Giá thuê (đ/tháng)"
            android:inputType="number"
            android:background="@android:color/white"
            android:paddingLeft="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etRoomArea"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Diện tích (m²)"
            android:inputType="number"
            android:background="@android:color/white"
            android:paddingLeft="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etRoomDescription"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:hint="Mô tả chi tiết phòng (Không bắt buộc)"
            android:inputType="textMultiLine"
            android:gravity="top|left"
            android:background="@android:color/white"
            android:padding="12dp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnSaveRoom"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="LƯU PHÒNG TRỌ"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"/>
    </LinearLayout>
</ScrollView>
