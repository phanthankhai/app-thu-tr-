<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/llBottomButtons">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="← Quay lại"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="20dp"
                android:elevation="4dp"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/ivRoomImage"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="16dp"
                    android:src="@android:drawable/ic_menu_gallery" />

                <TextView
                    android:id="@+id/tvDetailRoomName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Phòng --"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FF5722"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tvDetailStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Trạng thái: Đang tải..."
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDetailPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Giá tiền: Đang tải..."
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDetailArea"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Diện tích: Đang tải..."
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDetailElectricity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đơn giá điện: Đang tải..."
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDetailWater"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đơn giá nước: Đang tải..."
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginBottom="16dp"/>

                <!-- CONTRACT INFO SECTION -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="THÔNG TIN HỢP ĐỒNG"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvContractInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chưa có hợp đồng"
                    android:textSize="15sp"
                    android:layout_marginBottom="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginBottom="16dp"/>

                <!-- MEMBERS SECTION -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="THÀNH VIÊN TRONG PHÒNG"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/llTenantsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnAddMember"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ THÊM THÀNH VIÊN"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="#1976D2"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/llBottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_alignParentBottom="true">

        <Button
            android:id="@+id/btnCreateContract"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="LẬP HỢP ĐỒNG THUÊ"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnCreateBill"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="LẬP HÓA ĐƠN THÁNG"
            android:backgroundTint="#FF9800"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnAssignServices"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="CÀI ĐẶT DỊCH VỤ"
            android:backgroundTint="#1976D2"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnReportIncident"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="BÁO CÁO SỰ CỐ"
            android:backgroundTint="#FF9800"/>
    </LinearLayout>

</RelativeLayout>
